# building script for HoneyGUI

from building import *
import menu_config
from SCons.Script import Flatten
import os

cwd = GetCurrentDir()
CPPPATH = [cwd]
CPPPATH += [cwd + '\\root_image']
src = Split("""
""")

objs = []

CPPDEFINES = []

if GetDepend('CONFIG_REALTEK_BUILD_EXAMPLE_STREAM_WIDGET'):

    src += ['example_gui_stream.c']
    CPPDEFINES = ['DRV_LCD_WIDTH=460']
    CPPDEFINES += ['DRV_LCD_HEIGHT=502']
    CPPDEFINES += ['DRV_PIXEL_BITS=16']
    CPPDEFINES += ['DRV_LCD_CORNER_RADIUS=0']
    if hasattr(menu_config, 'ARCH') and menu_config.ARCH == 'win32':
        from honeygui import *

        print("Target arch is win32, attempting to add prebuilt binary object...")
        BIN_SUBDIR = os.path.join(cwd, 'root_image')
        additional_objs = []

        # MSV1 source: duck.avi shipped with this demo.
        BIN_FILE = os.path.join(BIN_SUBDIR, 'duck.avi')
        OBJ_FILE = os.path.join(BIN_SUBDIR, 'duck_avi.o')
        result_node = add_prebuilt_binary_object(BIN_FILE, OBJ_FILE)
        if result_node:
            additional_objs.append(result_node)

        # JPEG source: the MJPEG clip from the gui_video widget demo, embedded
        # in place from its own root_image (no copy into this demo).
        BIN_FILE = os.path.join(BIN_SUBDIR, 'earth_420_410_502_40_lq.mjpg')
        OBJ_FILE = os.path.join(BIN_SUBDIR, 'earth_420_410_502_40_lq_mjpg.o')
        result_node = add_prebuilt_binary_object(BIN_FILE, OBJ_FILE)
        if result_node:
            additional_objs.append(result_node)

        # H.264 source: birds clip in the custom "H264" container (24-byte
        # header + Annex-B elementary stream).  Only referenced by the opt-in
        # STREAM_DEMO_BIRDS build; embedded unconditionally so the symbol exists.
        BIN_FILE = os.path.join(BIN_SUBDIR, 'birds_header.h264')
        OBJ_FILE = os.path.join(BIN_SUBDIR, 'birds_header_h264.o')
        result_node = add_prebuilt_binary_object(BIN_FILE, OBJ_FILE)
        if result_node:
            additional_objs.append(result_node)

        if additional_objs:
            print(additional_objs)
            src = Flatten(src + additional_objs)

objs = DefineGroup('realgui/demo', src, depend = [''], CPPPATH = CPPPATH, CPPDEFINES = CPPDEFINES)

Return('objs')
